# Copy to .env (never commit .env). Used by utilities/sync-to-jira.js and sync-to-testrail.js

# Jira + Xray (existing)
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
XRAY_CLIENT_ID=
XRAY_CLIENT_SECRET=
JIRA_TEST_ISSUE_TYPE=Story
JIRA_LINK_TYPE_TEST_TO_STORY=Test

# TestRail (https://support.testrail.com/hc/en-us/articles/7034196267444-Accessing-the-API)
TESTRAIL_URL=https://eleksdemo.testrail.io
TESTRAIL_EMAIL=
# If login is not an email (rare): TESTRAIL_USER=your_login
# Basic-auth "password": use API key (recommended) OR account password (one of two)
TESTRAIL_API_KEY=
# TESTRAIL_PASSWORD=your_testrail_login_password
TESTRAIL_PROJECT_ID=2
# Шаблон кейсів з окремими кроками (у TestRail часто id 2 = «Test Case (Steps)»); інакше скрипт знайде сам
# TESTRAIL_TEMPLATE_ID=2
# Suite: explicit id, OR name (find/create), OR first suite in project
# (Якщо є тільки секція — задай TESTRAIL_SECTION_ID; suite_id підставиться з API, SUITE_* не обов’язкові.)
# TESTRAIL_SUITE_ID=1
# TESTRAIL_SUITE_NAME=TES / Master
# TESTRAIL_SUITE_DESCRIPTION=Optional description when creating suite
# Section id from UI URL / API — enough on its own for sync-to-testrail.js
# TESTRAIL_SECTION_ID=123
# Or exact name as in TestRail:
# TESTRAIL_SECTION_NAME=My Section
# Optional if Story Key is in each .md:
# TESTRAIL_STORY_KEY=TES-1

# Copy to .env (never commit .env). Used by utilities/sync-to-jira.js, validate-before-sync.js, fetch-story.js

# Jira + Xray
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
XRAY_CLIENT_ID=
XRAY_CLIENT_SECRET=
JIRA_TEST_ISSUE_TYPE=Story
JIRA_LINK_TYPE_TEST_TO_STORY=Test

# TestRail — for Cursor MCP only (@bun913/mcp-testrail). Set these in ~/.cursor/mcp.json under "testrail".env
# (not read by repo scripts). Copy values here for your own reference only.
# Upstream expects:
#   TESTRAIL_URL=https://your-instance.testrail.io
#   TESTRAIL_USERNAME=your-login-or-email   # same as TestRail profile login (often equals email)
#   TESTRAIL_API_KEY=                       # My Settings → API Keys → Save Settings
#
# Optional local notes (not used by MCP):
#   TESTRAIL_PROJECT_ID=2                   # remember project id when calling MCP tools
